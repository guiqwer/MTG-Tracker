# Dependencies
node_modules/
apps/*/node_modules/

# Build output
dist/
build/
apps/*/dist/

# Environment (keep .env.example committed)
.env
.env.local
.env.*.local

# Caches / generated
.vite/
*.tsbuildinfo
apps/api/src/generated/
coverage/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log

# Local-only compose override (publishes ports for local browsing)
docker-compose.override.yml

# Claude Code (machine-specific local settings)
.claude/settings.local.json

# OAuth skill tooling (vendored clones — not part of the app)
/api/
/oauth-developer-skills/
.claude/skills/

# Markdown docs are local-only (owner rule: no .md on GitHub)
*.md

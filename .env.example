# Postgres
POSTGRES_USER=mtg
POSTGRES_PASSWORD=mtg
POSTGRES_DB=mtgtracker
POSTGRES_PORT=5432

# Ports exposed to the host
API_PORT=3000
WEB_PORT=5173

# Used only when running prisma commands from the HOST (outside Docker).
# Inside Docker the api talks to the "db" service automatically.
DATABASE_URL=postgresql://mtg:mtg@localhost:5432/mtgtracker?schema=public

# Injected into the web build; the browser reaches the API on the host port.
VITE_API_URL=http://localhost:3000

# --- Auth (self-hosted JWT) ---
# REQUIRED in production. Use a long random string, e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-in-production
JWT_ISSUER=magic-match-tracker
JWT_AUDIENCE=magic-match-tracker-api
JWT_EXPIRES_IN=7d
